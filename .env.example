# ─────────────────────────────────────────────────────────────────────────────
# Mise Checklists — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is listed in .gitignore and must NEVER be committed to git.
#
# Vite embeds all VITE_* variables into the compiled JS bundle at build time.
# Only use VITE_* for values that are intentionally public (like Supabase keys).
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL — safe to expose, enforced by RLS policies.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon / publishable key — safe to expose, enforced by RLS.
# Find this in: Supabase Dashboard → Project Settings → API → Project API keys
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── PHASE 1 TEMPORARY — Admin Password ──────────────────────────────────────
#
# ⚠️  SECURITY NOTE:
# This password is embedded in the compiled client bundle by Vite. It is NOT
# truly secret — anyone who downloads and inspects the JS bundle can find it.
# It is only marginally better than hardcoding it in source.
#
# This gate exists purely for Phase 1 convenience. Phase 3 replaces it
# entirely with Supabase Auth (magic link + org_members role table), which
# provides real, server-enforced access control.
#
# In the meantime:
#   1. Change this from the default before deploying to any new venue.
#   2. Do NOT store sensitive data behind this gate.
#   3. Do NOT share this .env.local file.
#
# ─────────────────────────────────────────────────────────────────────────────
VITE_ADMIN_PW=change-me-before-deploying
